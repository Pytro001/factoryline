# Local: `npm run dev` loads this via dotenv (server.js). Vercel: set vars in the dashboard.
#
# Hosted LLM (works on Vercel — pick one)
# Free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Or OpenAI / Azure OpenAI-compatible
# OPENAI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Custom provider (both required)
# AI_API_KEY=
# AI_BASE_URL=https://your-endpoint/v1

# Local Ollama (npm run dev) — used when no keys above
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
